# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Gmail / Google OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8001/auth/gmail/callback
GMAIL_USER_EMAIL=

# Gmail Pub/Sub push notifications
GOOGLE_CLOUD_PROJECT_ID=
PUBSUB_TOPIC_NAME=gmail-push

# Integrations
APOLLO_API_KEY=your-apollo-api-key    # apollo.io → Settings → Integrations → API Key
APIFY_API_KEY=your-apify-key          # apify.com → Settings → Integrations → API tokens
VIBE_PROSPECTING_API_KEY=             # optional: vibe.co for recruiter search

# Dashboard auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme

# Optional API protection (recommended if the backend is reachable beyond localhost).
# When set, all /api/v1/* requests must send the X-API-Key header with this value;
# set the same value as NEXT_PUBLIC_API_KEY in frontend/.env.local.
API_KEY=

# Optional shared secret for the Gmail Pub/Sub push endpoint. When set,
# /webhooks/gmail requires ?token=<value> — add it to the push subscription URL.
PUBSUB_VERIFICATION_TOKEN=

# Pipeline config (cron expressions)
MORNING_PIPELINE_CRON=0 6 * * *
RETRY_PIPELINE_CRON=0 9 * * *

# Thresholds
ATS_CONFIDENCE_THRESHOLD=0.8

# LangGraph orchestration — local sqlite files for paused-run checkpoints and
# the application→thread registry (relative paths resolve from backend/)
ORCHESTRATOR_CHECKPOINT_DB=data/orchestrator_checkpoints.sqlite
ORCHESTRATOR_REGISTRY_DB=data/approval_threads.sqlite

# Gmail tracker migration (one-time, run scripts/migrate_gmail_tracker.py)
GMAIL_TRACKER_PG_HOST=localhost
GMAIL_TRACKER_PG_PORT=5432
GMAIL_TRACKER_PG_DB=gmail_tracker
GMAIL_TRACKER_PG_USER=postgres
GMAIL_TRACKER_PG_PASS=
